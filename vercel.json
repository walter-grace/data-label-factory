{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && cd web && npm install",
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/.next",
  "functions": {
    "api/index.py": {
      "includeFiles": "data_label_factory/**"
    }
  },
  "rewrites": [
    {
      "source": "/backend/:path*",
      "destination": "/api/index"
    }
  ]
}
